<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zeppelin Bar — Salta</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@300;400;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --black2: #111111;
    --black3: #1a1a1a;
    --gold: #c9922a;
    --gold-light: #e8b84b;
    --gold-dim: #7a5518;
    --ember: #d44a1a;
    --ember-dark: #8c2e0a;
    --white: #f5f0e8;
    --white-dim: #9a9280;
    --border: rgba(201,146,42,0.2);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Crimson Pro', Georgia, serif;
    overflow-x: hidden;
  }
  /* ---- NAV ---- */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    letter-spacing: 4px;
    color: var(--gold);
    text-decoration: none;
  }
  .nav-logo span { color: var(--white); }
  .nav-links {
    display: flex; gap: 32px; list-style: none;
  }
  .nav-links a {
    font-family: 'Oswald', sans-serif;
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--white-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold); }
  /* ---- HERO ---- */
  #hero {
    height: 100vh;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 80%, rgba(212,74,26,0.18) 0%, transparent 70%),
      radial-gradient(ellipse 80% 60% at 20% 60%, rgba(201,146,42,0.08) 0%, transparent 60%),
      #0a0a0a;
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(201,146,42,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,146,42,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
  }
  .hero-content {
    position: relative; z-index: 2;
    text-align: center;
    padding: 0 24px;
  }
  .hero-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 14vw, 180px);
    line-height: 0.9;
    letter-spacing: 8px;
    color: var(--white);
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero-title .accent { color: var(--gold); display: block; }
  .hero-sub {
    font-family: 'Crimson Pro', serif;
    font-style: italic;
    font-size: 20px;
    color: var(--white-dim);
    margin-top: 20px;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }
  .hero-ctas {
    display: flex; gap: 16px; justify-content: center;
    margin-top: 48px;
    opacity: 0;
    animation: fadeUp 0.8s 0.8s forwards;
  }
  .btn-primary {
    font-family: 'Oswald', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--black);
    background: var(--gold);
    border: none;
    padding: 14px 36px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-outline {
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    background: transparent;
    border: 1px solid rgba(245,240,232,0.3);
    padding: 14px 36px;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, transform 0.15s;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }
  .hero-scroll {
    position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0; animation: fadeIn 1s 1.2s forwards;
  }
  .hero-scroll span {
    font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 3px;
    text-transform: uppercase; color: var(--white-dim);
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(var(--gold), transparent);
    animation: scrollPulse 2s infinite;
  }
  /* ---- SECTIONS COMMON ---- */
  section { padding: 100px 0; }
  .section-wrap { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .section-label {
    font-family: 'Oswald', sans-serif;
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    letter-spacing: 3px;
    color: var(--white);
    line-height: 1;
  }
  .divider {
    width: 60px; height: 2px;
    background: var(--gold);
    margin: 24px 0 48px;
  }
  /* ---- NOSOTROS ---- */
  #nosotros { background: var(--black2); }
  .nosotros-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .nosotros-text p {
    font-size: 18px;
    line-height: 1.8;
    color: rgba(245,240,232,0.8);
    margin-bottom: 20px;
  }
  .nosotros-text p em {
    color: var(--gold);
    font-style: italic;
  }
  .nosotros-img {
    aspect-ratio: 3/4;
    background: var(--black3);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .nosotros-img::after {
    content: 'FOTO DEL BAR';
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Oswald', sans-serif;
    font-size: 12px; letter-spacing: 4px;
    color: var(--white-dim);
  }
  .nosotros-img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(10,10,10,0.8) 100%);
  }
  .stat-row {
    display: flex; gap: 48px; margin-top: 40px;
  }
  .stat { border-left: 2px solid var(--gold); padding-left: 16px; }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px; color: var(--gold); line-height: 1;
  }
  .stat-label {
    font-family: 'Oswald', sans-serif;
    font-size: 11px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--white-dim);
  }
  /* ---- MENU ---- */
  #menu { background: var(--black); }
  .menu-tabs {
    display: flex; gap: 0; margin-bottom: 48px;
    border-bottom: 1px solid var(--border);
  }
  .menu-tab {
    font-family: 'Oswald', sans-serif;
    font-weight: 400; font-size: 13px;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--white-dim);
    background: none; border: none; border-bottom: 2px solid transparent;
    padding: 12px 28px; cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    margin-bottom: -1px;
  }
  .menu-tab.active { color: var(--gold); border-bottom-color: var(--gold); }
  .menu-tab:hover { color: var(--white); }
  .menu-panel { display: none; }
  .menu-panel.active { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .menu-item {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 20px 0;
    border-bottom: 1px solid rgba(201,146,42,0.1);
  }
  .menu-item:nth-child(odd) { padding-right: 48px; }
  .menu-item:nth-child(even) { padding-left: 48px; border-left: 1px solid rgba(201,146,42,0.1); }
  .menu-item-info {}
  .menu-item-name {
    font-family: 'Oswald', sans-serif;
    font-weight: 400; font-size: 16px;
    color: var(--white); letter-spacing: 0.5px;
  }
  .menu-item-desc {
    font-size: 13px; font-style: italic;
    color: var(--white-dim); margin-top: 4px;
  }
  .menu-item-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px; color: var(--gold);
    white-space: nowrap; margin-left: 16px;
  }
  .menu-badge {
    font-family: 'Oswald', sans-serif;
    font-size: 9px; letter-spacing: 2px; text-transform: uppercase;
    background: var(--ember-dark); color: var(--white);
    padding: 2px 8px; margin-left: 8px; vertical-align: middle;
  }
  /* ---- PEDIDOS ---- */
  #pedidos {
    background: var(--black3);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .pedidos-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 48px;
  }
  .pedidos-text .section-title { font-size: 56px; }
  .pedidos-text p {
    font-size: 18px; color: var(--white-dim);
    font-style: italic; margin: 16px 0 32px;
    max-width: 420px; line-height: 1.7;
  }
  .pedidos-badge {
    display: inline-flex; align-items: center; gap: 12px;
    background: rgba(201,146,42,0.08);
    border: 1px solid var(--border);
    padding: 16px 24px;
  }
  .pedidos-badge-icon {
    width: 40px; height: 40px;
    background: var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .pedidos-badge-text {
    font-family: 'Oswald', sans-serif;
    font-size: 11px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--white-dim);
  }
  .pedidos-badge-text strong {
    display: block; font-size: 18px; letter-spacing: 1px;
    color: var(--gold); font-weight: 600;
  }
  .pedidos-visual {
    flex-shrink: 0; width: 300px; height: 300px;
    background: var(--black2);
    border: 1px solid var(--border);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .pedidos-visual::before {
    content: '';
    position: absolute; inset: -50%;
    background: conic-gradient(from 0deg, transparent 0deg, rgba(201,146,42,0.08) 30deg, transparent 60deg);
    animation: rotateSlow 8s linear infinite;
  }
  .pedidos-visual-inner { position: relative; z-index: 2; text-align: center; }
  .pedidos-visual-icon { font-size: 56px; display: block; margin-bottom: 12px; }
  .pedidos-visual-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px; letter-spacing: 4px;
    color: var(--gold);
  }
  /* ---- GALERIA ---- */
  #galeria { background: var(--black2); }
  .galeria-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 280px 280px;
    gap: 4px;
  }
  .galeria-item {
    background: var(--black3);
    border: 1px solid var(--border);
    position: relative; overflow: hidden;
    cursor: pointer;
  }
  .galeria-item:first-child { grid-row: 1 / 3; }
  .galeria-item::after {
    content: attr(data-label);
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Oswald', sans-serif;
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--white-dim);
    transition: opacity 0.3s;
  }
  .galeria-item::before {
    content: '';
    position: absolute; inset: 0;
    background: rgba(201,146,42,0.0);
    transition: background 0.3s;
    z-index: 1;
  }
  .galeria-item:hover::before { background: rgba(201,146,42,0.12); }
  .galeria-item:hover::after { opacity: 0.3; }
  /* ---- JUEGOS ---- */
  #juegos { background: var(--black); }
  .juegos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 900px;
  }
  .juego-card {
    background: var(--black3);
    border: 1px solid var(--border);
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
    cursor: default;
  }
  .juego-card:hover { border-color: var(--gold); }
  .juego-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }
  .juego-card:hover::before { transform: scaleX(1); }
  .juego-icon { font-size: 36px; margin-bottom: 16px; display: block; }
  .juego-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px; letter-spacing: 2px;
    color: var(--white); margin-bottom: 8px;
  }
  .juego-desc {
    font-size: 15px; line-height: 1.7;
    color: var(--white-dim); font-style: italic;
  }
  /* ---- CONTACTO ---- */
  #contacto {
    background: var(--black2);
    border-top: 1px solid var(--border);
  }
  .contacto-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .contacto-map {
    aspect-ratio: 4/3;
    background: var(--black3);
    border: 1px solid var(--border);
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .contacto-map-text {
    font-family: 'Oswald', sans-serif;
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--white-dim);
  }
  .contact-item {
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(201,146,42,0.1);
  }
  .contact-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .contact-label {
    font-family: 'Oswald', sans-serif;
    font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 8px;
  }
  .contact-value {
    font-family: 'Crimson Pro', serif;
    font-size: 20px; color: var(--white); line-height: 1.5;
  }
  .contact-value a { color: inherit; text-decoration: none; }
  .contact-value a:hover { color: var(--gold); }
  /* ---- FOOTER ---- */
  footer {
    background: var(--black);
    border-top: 1px solid var(--border);
    padding: 48px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px; letter-spacing: 5px;
    color: var(--gold);
  }
  .footer-logo span { color: var(--white-dim); }
  .footer-text {
    font-family: 'Oswald', sans-serif;
    font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    color: var(--white-dim);
    text-align: center;
  }
  .footer-social { display: flex; gap: 20px; }
  .footer-social a {
    font-family: 'Oswald', sans-serif;
    font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    color: var(--white-dim); text-decoration: none;
    transition: color 0.2s;
  }
  .footer-social a:hover { color: var(--gold); }
  /* ---- ANIMATIONS ---- */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }
  @keyframes rotateSlow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  /* ---- RESPONSIVE ---- */
  @media (max-width: 900px) {
    nav { padding: 0 24px; }
    .nav-links { display: none; }
    .section-wrap { padding: 0 24px; }
    section { padding: 72px 0; }
    .nosotros-grid,
    .contacto-grid { grid-template-columns: 1fr; gap: 40px; }
    .menu-panel.active { grid-template-columns: 1fr; }
    .menu-item:nth-child(even) { padding-left: 0; border-left: none; }
    .juegos-grid { grid-template-columns: 1fr; }
    .galeria-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .galeria-item:first-child { grid-row: auto; grid-column: 1 / 3; }
    .pedidos-inner { flex-direction: column; }
    .pedidos-visual { width: 100%; }
    footer { flex-direction: column; gap: 24px; text-align: center; }
    .stat-row { gap: 24px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#hero" class="nav-logo" style="display:flex;align-items:center;"><img src="data:image/png;base64," alt="Zeppelin Bar" style="height:44px; width:auto;"></a>
  <ul class="nav-links">
    <li><a href="#nosotros">Nosotros</a></li>
